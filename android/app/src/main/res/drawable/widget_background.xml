<?xml version="1.0" encoding="utf-8"?>
<!-- Fichier : android/app/src/main/res/drawable/widget_background.xml -->
<!-- Fond beige élégant avec bords arrondis et ombre douce -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Ombre douce -->
    <item
        android:top="3dp"
        android:left="2dp"
        android:right="2dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#14A07850" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Fond principal beige élégant -->
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <!-- Beige chaud et élégant : ivoire doré -->
            <solid android:color="#FAF6F0" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#E8D8C4" />
        </shape>
    </item>

</layer-list>