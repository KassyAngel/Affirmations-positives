<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fond dégradé beige/orange — reprend exactement les couleurs de l'app -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#FFF5F0"
                android:centerColor="#FFE8DC"
                android:endColor="#FFF0E8" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Overlay très léger pour adoucir -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#08FF8C69" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Bordure fine orange douce -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="1dp"
                android:color="#30FF8C69" />
            <corners android:radius="24dp" />
        </shape>
    </item>

</layer-list>