<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Ombre subtile -->
    <item android:top="2dp" android:left="1dp" android:right="1dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#18B07040" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <!-- Fond principal — blanc cassé légèrement plus chaud pour meilleur contraste -->
    <item android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#FFFAF5"
                android:endColor="#FFF2E6" />
            <corners android:radius="22dp" />
            <stroke android:width="1dp" android:color="#22B07040" />
        </shape>
    </item>
</layer-list>