<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fond principal blanc cassé chaud -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="150"
                android:startColor="#FFFCF8"
                android:centerColor="#FFF7EE"
                android:endColor="#FFF0E0" />
            <corners android:radius="20dp" />
            <stroke android:width="1dp" android:color="#30C9956A" />
        </shape>
    </item>

    <!-- Liseré doré subtil en haut -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#22C9956A"
                android:endColor="#00C9956A" />
            <corners android:radius="20dp" />
        </shape>
    </item>

</layer-list>