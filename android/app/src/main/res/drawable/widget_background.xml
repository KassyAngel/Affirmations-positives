<?xml version="1.0" encoding="utf-8"?>
<!-- Fichier : android/app/src/main/res/drawable/widget_background.xml -->
<!-- Fond blanc rosé avec bords arrondis et légère ombre -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Ombre légère -->
    <item
        android:top="2dp"
        android:left="2dp"
        android:right="2dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#18000000" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <!-- Fond principal blanc rosé -->
    <item
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFF1F2" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="#FECDD3" />
        </shape>
    </item>
</layer-list>